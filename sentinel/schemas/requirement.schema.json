{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ignite Sentinel Requirement",
  "type": "object",
  "required": ["id", "source_ids", "status", "domains", "statement"],
  "properties": {
    "id": { "type": "string", "pattern": "^REQ-(?:[0-9]{3}|EARS-[0-9]{3})$" },
    "source_ids": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "domains": { "type": "array", "items": { "type": "string" } },
    "statement": { "type": "string" },
    "expected_evidence": {
      "type": "object",
      "required": ["kind", "rationale"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "ears": {
      "type": "object",
      "required": ["pattern", "source_ids"],
      "properties": {
        "pattern": {
          "type": "string",
          "enum": ["ubiquitous", "event", "state", "unwanted", "optional"]
        },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
