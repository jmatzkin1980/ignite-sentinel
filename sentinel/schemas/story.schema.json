{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ignite Sentinel User Story",
  "type": "object",
  "required": ["id", "parent_ids", "status", "story", "acceptance_criteria"],
  "properties": {
    "id": { "type": "string", "pattern": "^US-[0-9]{3}$" },
    "parent_ids": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "label": { "type": "string" },
    "slicing_pattern": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "trace": { "type": "array", "items": { "type": "string" } },
    "context_pack": { "type": "string" },
    "domain_context_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain", "evidence", "status", "impact"],
        "properties": {
          "domain": { "type": "string" },
          "evidence": { "type": "string" },
          "status": { "type": "string", "enum": ["Confirmed", "Pending", "Not Applicable"] },
          "impact": { "type": "string" }
        }
      }
    },
    "agent_execution_contract": {
      "type": "object",
      "properties": {
        "readiness": { "type": "string" },
        "agent_profile": { "type": "string" },
        "decision_priority": { "type": "string" },
        "commands": { "type": "object" },
        "critical_surfaces": { "type": "object" },
        "design_match": { "type": "object" },
        "engineering_practices": { "type": "object" },
        "validation": { "type": "object" },
        "autonomy": { "type": "object" },
        "blast_radius": { "type": "array", "items": { "type": "string" } },
        "parallelization": { "type": "string" }
      }
    },
    "story": { "type": "string" },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["id", "given", "when", "then"],
            "properties": {
              "id": { "type": "string", "pattern": "^AC-[0-9]{3}(?:-[0-9]{2})?$" },
              "name": { "type": "string" },
              "classification": { "type": "string", "enum": ["fail-to-pass", "pass-to-pass", "evidence", "acceptance"] },
              "given": { "type": "string" },
              "when": { "type": "string" },
              "then": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
