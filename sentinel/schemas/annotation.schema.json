{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ignite-sentinel.local/schemas/annotation.schema.json",
  "title": "Ignite Sentinel Agent Annotation",
  "description": "Input contract for /annotate: the agent's structured semantic analysis. Each gap is validated in code by validate_agent_gaps (shared with /challenge, /scrutinize, and the implementability probe) — every gap must cite verbatim local evidence.",
  "type": "object",
  "required": ["gaps"],
  "additionalProperties": true,
  "properties": {
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "lens", "severity", "question", "evidence"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^GAP-[A-Z0-9-]+$"
          },
          "lens": {
            "type": "string",
            "enum": ["business", "product", "quality", "technical", "compliance", "delivery", "design"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1,
            "description": "Verbatim local quote from raw input or domain context."
          },
          "unit": {
            "type": "string",
            "pattern": "^RU-[0-9]{3}$",
            "description": "Optional Requirement Unit id (IMP-116) the gap belongs to."
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
