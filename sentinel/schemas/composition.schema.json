{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ignite Sentinel PRD Composition Draft",
  "type": "object",
  "required": ["blocks"],
  "properties": {
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section", "paragraphs"],
        "properties": {
          "id": { "type": "string" },
          "section": { "type": "string", "pattern": "^[0-9]+$" },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text", "citations"],
              "properties": {
                "text": { "type": "string", "minLength": 1 },
                "citations": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  }
}
