{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ignite-sentinel.local/schemas/assumption.schema.json",
  "title": "Ignite Sentinel Governed Assumptions",
  "type": "object",
  "additionalProperties": false,
  "required": ["assumptions"],
  "properties": {
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "lens", "statement", "owner", "risk", "justification"],
        "properties": {
          "id": { "type": "string", "pattern": "^ASM-[A-Z0-9-]+$" },
          "lens": {
            "type": "string",
            "enum": ["business", "product", "design", "technical", "technology", "quality", "compliance", "delivery"]
          },
          "statement": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "risk": { "type": "string", "enum": ["low", "med", "medium", "high"] },
          "uncertainty": { "type": "string", "enum": ["low", "med", "medium", "high"] },
          "justification": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "closes_gap": { "type": "string", "pattern": "^GAP-[A-Z0-9-]+$" },
          "risk_category": {
            "type": "string",
            "enum": ["value", "usability", "viability", "feasibility"],
            "description": "Optional. Which of Cagan's four product risks the assumption is about. Extensible per project via a risk-category directory override (sentinel/risk_category_registry.py); this enum lists the default four."
          }
        }
      }
    }
  }
}
