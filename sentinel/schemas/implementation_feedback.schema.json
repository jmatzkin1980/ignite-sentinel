{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ignite Sentinel Implementation Feedback",
  "type": "object",
  "required": ["findings"],
  "additionalProperties": false,
  "properties": {
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "summary", "evidence"],
        "anyOf": [
          { "required": ["story"] },
          { "required": ["story_id"] }
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": ["new-dependency", "gap", "ac-challenge", "surface-not-covered"]
          },
          "story": {
            "type": "string",
            "pattern": "^US-[0-9]{3}$"
          },
          "story_id": {
            "type": "string",
            "pattern": "^US-[0-9]{3}$"
          },
          "acceptance_criteria": {
            "type": "string",
            "pattern": "^AC-[0-9]{3}-[0-9]{2}$"
          },
          "gap_id": {
            "type": "string",
            "pattern": "^GAP-[A-Z0-9-]+$"
          },
          "status": {
            "enum": ["open", "resolved"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "source": { "type": "string" },
          "source_units": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^SPEC-U-[0-9]{3}$"
            }
          },
          "blocks_dod": { "type": "boolean" },
          "mark_stale": { "type": "boolean" }
        }
      }
    }
  }
}
