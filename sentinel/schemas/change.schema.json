{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ignite Sentinel Change",
  "type": "object",
  "required": ["id", "source_path", "status", "affected_ids"],
  "properties": {
    "id": { "type": "string", "pattern": "^CHG-[0-9]{3}$" },
    "source_path": { "type": "string" },
    "status": { "enum": ["pending", "applied", "rejected"] },
    "affected_ids": { "type": "array", "items": { "type": "string" } }
  }
}
