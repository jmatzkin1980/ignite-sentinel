{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ignite-sentinel.local/schemas/requirement_unit.schema.json",
  "title": "Ignite Sentinel Requirement Unit",
  "type": "object",
  "required": ["id", "label", "evidence_mention", "source", "raw_id", "trace_id"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RU-[0-9]{3}$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "evidence_mention": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string"
    },
    "raw_id": {
      "type": "string",
      "pattern": "^RAW-[0-9]{3}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^RU-[0-9]{3}$"
    }
  }
}
